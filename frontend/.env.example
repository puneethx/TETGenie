# ─────────────────────────────────────────────────────────────
# TETGenie frontend environment — copy to `.env` and fill in.
# Get these values from Firebase Console → Project Settings →
# "Your apps" → Web app → SDK setup and configuration.
# (Step-by-step guide is in the project README.)
# All VITE_* vars are embedded in the client bundle — that is
# expected for Firebase web config; security is enforced by
# Firebase Security Rules, NOT by hiding these keys.
# ─────────────────────────────────────────────────────────────
VITE_FIREBASE_API_KEY=AIzaSyA1_qYrNzNJbIXAh0nTfjIqknWP208LJrI
VITE_FIREBASE_AUTH_DOMAIN=tetgenie.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=tetgenie
VITE_FIREBASE_STORAGE_BUCKET=tetgenie.firebasestorage.app
VITE_FIREBASE_MESSAGING_SENDER_ID=546285079884
VITE_FIREBASE_APP_ID=1:546285079884:web:256275b00e4ce0cc5593e9


# URL of the Railway AI backend (used only for PDF extraction & paper generation).
# Leave blank during early frontend-only development.
VITE_AI_BACKEND_URL=

# Your TETGenie WhatsApp community invite link (shown on the premium unlock screen).
VITE_WHATSAPP_COMMUNITY_URL=https://chat.whatsapp.com/BTMDRT3WRyMIDSiXhp7dWx
