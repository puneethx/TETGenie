# ─────────────────────────────────────────────────────────────
# TETGenie AI backend — copy to `.env` for local dev.
# On Railway, set these as service Variables instead (do NOT commit .env).
# NOTE: parsed literally — the client secret's `$` is safe here, but never
# `source` this file in bash.
# ─────────────────────────────────────────────────────────────

# ── SAP AI Core (from your BTP AI Core service key) ──
AICORE_TOKEN_URL=https://infy-sap-nts-ai.authentication.eu10.hana.ondemand.com/oauth/token
AICORE_CLIENT_ID=sb-551011ad-7080-4f4f-8df2-e0d6502372f2!b268695|aicore!b540
AICORE_CLIENT_SECRET=cd6c8d2b-ba5c-487f-87aa-30011181e7fb$AvD2k8ApPg1mHmttkxKi_ESQqgdDde73Z_k8sZQMFxM=
AICORE_BASE_URL=https://api.ai.prod.eu-central-1.aws.ml.hana.ondemand.com
AICORE_RESOURCE_GROUP=default
AICORE_DEPLOYMENT_ID=d39238ee9fce9c84
AICORE_MODEL_NAME=anthropic--claude-4.6-opus

# ── Firebase (used only to verify caller ID tokens; no service account) ──
FIREBASE_PROJECT_ID=tetgenie
# Comma-separated admin emails allowed to run AI jobs (recommended).
# The email is a verified claim in the Firebase ID token.
ADMIN_EMAILS=umamaheswari1999@gmail.com

# ── CORS: your frontend origin(s), comma-separated. Use * only for local dev ──
CORS_ORIGINS=http://localhost:5173

# ── Local-dev escape hatch ONLY: set to 1 to skip token verification ──
DISABLE_AUTH=0

# ── Extraction tuning (optional) ──
RENDER_DPI=170
VISION_CONCURRENCY=5
MAX_PDF_MB=40
